{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "compaction": {
    "auto": true,
    "prune": false
  },
  "permission": {
    "*": "ask",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "question": "allow",
    "todowrite": "allow",
    "doom_loop": "deny",
    "websearch": "deny",
    "codesearch": "deny",
    "webfetch": "deny", // better to use duckduckgo mcp instead
    "duckduckgo*": "allow",
    "bash": {
      "ls *": "allow",
      "find *": "allow",
      "cat *": "allow",
      "echo *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "diff *": "allow",
      "git diff *": "allow",
      "git status *": "allow",
      "git log *": "allow"
    }
  },
  "agent": {
    "plan": {
      "permission": {
        "edit": "deny"
      }
    },
    "build": {
      "permission": {
        "edit": "allow"
      }
    }
  },
  "mcp": {
    "duckduckgo": {
      "type": "local",
      "command": ["uvx", "duckduckgo-mcp-server"],
      "environment": {
        "DDG_SAFE_SEARCH": "OFF",
        "DDG_REGION": "wt-wt"
      }
    }
  },
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"
      },
      "models": {
        "local-model": {
          "name": "Local Model",
          "limit": {
            "context": 128000,
            "output": 32000
          }
        }
      }
    }
  }
}
