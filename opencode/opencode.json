{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "model": "opencode-go/deepseek-v4-flash",
  "small_model": "opencode-go/deepseek-v4-flash",
  "plugin": ["@mohak34/opencode-notifier@latest"],
  "permission": {
    "*": "ask",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "task": "allow",
    "skill": "deny",
    "question": "deny",
    "todowrite": "deny",
    "doom_loop": "deny",
    "codesearch": "deny",
    "websearch": "deny",
    "webfetch": "deny",
    "duckduckgo*": "deny",
    "sleep": "deny",
    "bash": {
      // Replaced by tools
      "ls *": "deny",
      "find *": "deny",
      "cat *": "deny",
      "echo *": "deny",
      "head *": "deny",
      "tail *": "deny",
      "sed *": "deny",
      "tee *": "deny",
      "touch *": "deny",
      "grep *": "deny",
      "rg *": "deny",
      "wc *": "deny",
      // Other commands with no tool equivalent
      "tree *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "which *": "allow",
      "diff *": "allow",
      "git diff *": "allow",
      "git status *": "allow",
      "git log *": "allow",
      "git show *": "allow"
    }
  },
  "agent": {
    "plan": {
      "color": "info",
      "permission": {
        "edit": "deny"
      }
    },
    "build": {
      "color": "warning",
      "permission": {
        "edit": "allow"
      }
    },
    "explore": {
      "model": "opencode-go/deepseek-v4-flash",
      "permission": {
        "*": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow"
      }
    },
    "general": {
      "disable": true
    },
    "compaction": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "title": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "summary": {
      "model": "opencode-go/deepseek-v4-flash"
    }
  },
  "mcp": {
    "duckduckgo": {
      "type": "local",
      "command": ["uvx", "duckduckgo-mcp-server"],
      "environment": {
        "DDG_SAFE_SEARCH": "OFF",
        "DDG_REGION": "wt-wt"
      }
    }
  },
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"
      },
      "models": {
        "local-model": {
          "name": "Local Model",
          "limit": {
            "context": 128000,
            "output": 32000
          }
        }
      }
    }
  }
}
