{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "small_model": "github-copilot/gpt-5-mini",
  "compaction": {
    "auto": true,
    "prune": false
  },
  "permission": {
    "*": "ask",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "webfetch": "allow",
    "bash": {
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "diff *": "allow",
      "git diff *": "allow",
      "git status *": "allow",
      "git log *": "allow"
    }
  },
  "agent": {
    "build": {
      "permission": {
        "edit": "allow"
      }
    }
  }
}
