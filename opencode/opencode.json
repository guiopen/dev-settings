{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "compaction": {
    "auto": true,
    "prune": false
  },
  "permission": {
    "*": "ask",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "task": "deny",
    "skill": "deny",
    "question": "deny",
    "todowrite": "deny",
    "doom_loop": "deny",
    "websearch": "deny",
    "codesearch": "deny",
    "webfetch": "deny", // better to use duckduckgo mcp instead
    "duckduckgo*": "allow",
    "bash": {
      // navigation
      "ls *": "allow",
      "find *": "allow",
      "tree *": "allow",
      "du *": "allow",
      "pwd": "allow",
      // reading
      "cat *": "allow",
      "echo *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "file *": "allow",
      "stat *": "allow",
      // search
      "grep *": "allow",
      "rg *": "allow",
      // text transformation
      "sort *": "allow",
      "uniq *": "allow",
      "cut *": "allow",
      "awk *": "allow",
      "jq *": "allow",
      // comparison
      "diff *": "allow",
      // system/environment
      "which *": "allow",
      "type *": "allow",
      "env": "allow",
      "printenv *": "allow",
      // git
      "git diff *": "allow",
      "git status *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git blame *": "allow",
      "git branch *": "allow",
      "git stash list": "allow",
      // programming languages
      "node --version": "allow",
      "python --version": "allow",
      "python3 --version": "allow",
      "python -m py_compile *": "allow",
      "python3 -m py_compile *": "allow"
    }
  },
  "agent": {
    "plan": {
      "permission": {
        "edit": "deny"
      }
    },
    "build": {
      "permission": {
        "edit": "allow"
      }
    },
    "general": {
      "disable": true
    },
    "explore": {
      "disable": true
    }
  },
  "mcp": {
    "duckduckgo": {
      "type": "local",
      "command": ["uvx", "duckduckgo-mcp-server"],
      "environment": {
        "DDG_SAFE_SEARCH": "OFF",
        "DDG_REGION": "wt-wt"
      }
    }
  },
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"
      },
      "models": {
        "local-model": {
          "name": "Local Model",
          "limit": {
            "context": 128000,
            "output": 32000
          }
        }
      }
    }
  }
}
