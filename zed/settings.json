// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "disable_ai": true,
  "base_keymap": "VSCode",
  "file_scan_inclusions": ["node_modules/"],
  "format_on_save": "off",
  "sticky_scroll": { "enabled": true },
  "use_on_type_format": false,
  "ensure_final_newline_on_save": false,
  "remove_trailing_whitespace_on_save": false,
  "autosave": { "after_delay": { "milliseconds": 1000 } },
  "tabs": { "file_icons": true },
  "resize_all_panels_in_dock": [], // [] means every panel has its own size
  "project_panel": { "git_status": false, "dock": "left", "hide_root": true },
  "git_panel": { "dock": "left" },
  "outline_panel": { "button": false },
  "collaboration_panel": { "button": false },
  "search": { "center_on_match": true, "button": false },
  "search_wrap": false,
  "debugger": { "button": false },
  "gutter": { "bookmarks": false, "breakpoints": false },
  "scrollbar": { "search_results": false },
  "toolbar": { "quick_actions": false },
  "tab_bar": {
    "show_tab_bar_buttons": false,
    "show_pinned_tabs_in_separate_row": true,
    "show_nav_history_buttons": false,
  },

  "lsp": {
    "gopls": {
      "settings": {
        "usePlaceholders": false,
      },
    },
  },

  "theme": {
    "mode": "dark",
    "dark": "Zedokai (Filter Spectrum)",
    "light": "Zedokai Light (Filter Sun)",
  },
  "icon_theme": "Material Icon Theme",
  "ui_font_family": "Inter",
  "buffer_font_family": "JetBrains Mono",
  "ui_font_size": 15.0,
  "buffer_font_size": 16.0,
  "agent_ui_font_size": 16.0,
  "agent_buffer_font_size": 15.0,
  "ui_font_weight": 500.0,
  "buffer_font_weight": 400.0,
  "buffer_line_height": { "custom": 1.5 },

  "auto_install_extensions": {
    "material-icon-theme": true,
    "zedokai": true,
  },
}
